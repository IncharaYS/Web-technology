<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Parcel Management System</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;}

body{
    background: linear-gradient(135deg, #e0f2fe, #f0fdf4);
    font-family:'Segoe UI',sans-serif;
    min-height:100vh;
    display:flex;
    flex-direction:column;
}

/* NAVBAR */
.navbar{
    display:flex;
    align-items:center;
    padding:15px 20px;
    background:#1f2d3d;
    color:white;
}
.navbar a{
    color:white;
    text-decoration:none;
    font-weight:bold;
}
.ms-auto{margin-left:auto;}
.me-2{margin-right:10px;}

/* CONTAINER */
.container{
    width:90%;
    max-width:1100px;
    margin:auto;
}

/* HERO */
.hero{margin-top:80px;text-align:center;}

/* CARD */
.card{
    background:white;
    border-radius:12px;
    padding:35px;
    box-shadow:0 8px 25px rgba(0,0,0,0.08);
    max-width:400px;
    margin:auto;
}

/* BUTTONS */
.btn{
    display:block;
    width:100%;
    padding:12px;
    border-radius:10px;
    text-decoration:none;
    text-align:center;
    color:white;
    margin-bottom:10px;
}
.btn-primary{background:#2563eb;}
.btn-success{background:#16a34a;}
.btn-outline-light{
    border:1px solid white;
    background:transparent;
    color:white;
    padding:8px 12px;
}

/* FOOTER */
.footer{
    margin-top:auto;
    background:#1f2d3d;
    color:white;
    text-align:center;
    padding:12px;
}
</style>
</head>

<body>

<nav class="navbar">
    <span style="font-weight:bold;">Parcel Management System</span>
    <div class="ms-auto">
        <a href="register.html" class="btn-outline-light me-2">Register</a>
        <a href="login.html" class="btn-outline-light">Login</a>
    </div>
</nav>

<div class="container hero">
    <h1>Welcome</h1>
    <p style="color:#6b7280;">Efficient and secure parcel handling platform</p>

    <div class="card">
        <a href="register.html" class="btn btn-success">Register</a>
        <a href="login.html" class="btn btn-primary">Login</a>
    </div>
</div>

<footer class="footer">
© 2026 Parcel Management System
</footer>

</body>
</html>
